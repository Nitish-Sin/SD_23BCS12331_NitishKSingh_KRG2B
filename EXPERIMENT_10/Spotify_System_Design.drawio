        </mxCell>
        <mxCell id="fr-header" parent="1" style="whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" value="Functional Requirements" vertex="1">
          <mxGeometry height="30" width="220" x="-200" y="40" as="geometry" />
        </mxCell>
        <mxCell id="fr-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. Users should be able to register/login." vertex="1">
          <mxGeometry height="30" width="290" x="-200" y="90" as="geometry" />
        </mxCell>
        <mxCell id="fr-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="2. Users can search for songs, albums, artists, and playlists." vertex="1">
          <mxGeometry height="30" width="360" x="-200" y="130" as="geometry" />
        </mxCell>
        <mxCell id="fr-3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="3. Users can stream songs (play/pause/skip)." vertex="1">
          <mxGeometry height="30" width="310" x="-200" y="170" as="geometry" />
        </mxCell>
        <mxCell id="fr-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="4. Users can create and manage playlists." vertex="1">
          <mxGeometry height="30" width="280" x="-200" y="210" as="geometry" />
        </mxCell>
        <mxCell id="fr-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="5. Users can follow artists and other users." vertex="1">
          <mxGeometry height="30" width="290" x="-200" y="250" as="geometry" />
        </mxCell>
        <mxCell id="fr-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="6. System should provide personalized recommendations." vertex="1">
          <mxGeometry height="30" width="350" x="-200" y="290" as="geometry" />
        </mxCell>
        <mxCell id="fr-7" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="7. Artists can upload their songs (Admin/Artist portal)." vertex="1">
          <mxGeometry height="30" width="340" x="-200" y="330" as="geometry" />
        </mxCell>
        <mxCell id="nfr-header" parent="1" style="whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" value="Non-Functional Requirements" vertex="1">
          <mxGeometry height="30" width="220" x="-200" y="460" as="geometry" />
        </mxCell>
        <mxCell id="nfr-1" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="1. Scale: 500M users, 100M DAU, 50M songs" vertex="1">
          <mxGeometry height="30" width="310" x="-200" y="510" as="geometry" />
        </mxCell>
        <mxCell id="nfr-2" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="    → ~1M concurrent streams at peak" vertex="1">
          <mxGeometry height="30" width="290" x="-200" y="540" as="geometry" />
        </mxCell>
        <mxCell id="nfr-3" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="2. CAP Theorem: Availability &gt;&gt; Consistency" vertex="1">
          <mxGeometry height="30" width="300" x="-200" y="590" as="geometry" />
        </mxCell>
        <mxCell id="nfr-3b" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="    (Eventual Consistency is acceptable)" vertex="1">
          <mxGeometry height="30" width="280" x="-200" y="620" as="geometry" />
        </mxCell>
        <mxCell id="nfr-4" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="3. Latency: &lt; 200ms to start playback" vertex="1">
          <mxGeometry height="30" width="270" x="-200" y="660" as="geometry" />
        </mxCell>
        <mxCell id="nfr-5" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="4. Storage: ~50M songs × 5MB avg = ~250TB" vertex="1">
          <mxGeometry height="30" width="310" x="-200" y="700" as="geometry" />
        </mxCell>
        <mxCell id="nfr-6" parent="1" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" value="5. Highly reliable: No audio drops during streaming." vertex="1">
