  <diagram name="Page-1" id="73BWlclsNEQV3dTpjliq">
    <mxGraphModel dx="2135" dy="1093" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="6w1dBnIsRTiaIesn1pbN-1" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;h1 data-section-id=&quot;1uuyi2i&quot; data-start=&quot;401&quot; data-end=&quot;464&quot;&gt;Experiment: Design a YouTube-Like Video Streaming Application&lt;/h1&gt;&#xa;&lt;h2 data-section-id=&quot;5ixcdd&quot; data-start=&quot;466&quot; data-end=&quot;485&quot;&gt;Core Requirement&lt;/h2&gt;&#xa;&lt;p data-start=&quot;486&quot; data-end=&quot;586&quot;&gt;Client should be able to &lt;strong data-start=&quot;511&quot; data-end=&quot;585&quot;&gt;upload videos and watch videos from other users in real-time streaming&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;hr data-start=&quot;588&quot; data-end=&quot;591&quot;&gt;&#xa;&lt;h1 data-section-id=&quot;1pqndid&quot; data-start=&quot;593&quot; data-end=&quot;618&quot;&gt;Functional Requirements&lt;/h1&gt;&#xa;&lt;ol data-start=&quot;620&quot; data-end=&quot;1242&quot;&gt;&#xa;&lt;li data-section-id=&quot;8z31ff&quot; data-start=&quot;620&quot; data-end=&quot;669&quot;&gt;&#xa;&lt;p data-start=&quot;623&quot; data-end=&quot;669&quot;&gt;User should be able to &lt;strong data-start=&quot;646&quot; data-end=&quot;668&quot;&gt;register and login&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;94osuw&quot; data-start=&quot;671&quot; data-end=&quot;715&quot;&gt;&#xa;&lt;p data-start=&quot;674&quot; data-end=&quot;715&quot;&gt;User should be able to &lt;strong data-start=&quot;697&quot; data-end=&quot;714&quot;&gt;upload videos&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;f29iil&quot; data-start=&quot;717&quot; data-end=&quot;779&quot;&gt;&#xa;&lt;p data-start=&quot;720&quot; data-end=&quot;779&quot;&gt;User should be able to &lt;strong data-start=&quot;743&quot; data-end=&quot;778&quot;&gt;watch videos uploaded by others&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;6nrmga&quot; data-start=&quot;781&quot; data-end=&quot;848&quot;&gt;&#xa;&lt;p data-start=&quot;784&quot; data-end=&quot;848&quot;&gt;System should support &lt;strong data-start=&quot;806&quot; data-end=&quot;847&quot;&gt;video streaming with adaptive quality&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1xo56mv&quot; data-start=&quot;850&quot; data-end=&quot;916&quot;&gt;&#xa;&lt;p data-start=&quot;853&quot; data-end=&quot;916&quot;&gt;User should be able to &lt;strong data-start=&quot;876&quot; data-end=&quot;915&quot;&gt;like, dislike and comment on videos&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;xkk5q6&quot; data-start=&quot;918&quot; data-end=&quot;970&quot;&gt;&#xa;&lt;p data-start=&quot;921&quot; data-end=&quot;970&quot;&gt;User should be able to &lt;strong data-start=&quot;944&quot; data-end=&quot;969&quot;&gt;subscribe to channels&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;gbjgvn&quot; data-start=&quot;972&quot; data-end=&quot;1033&quot;&gt;&#xa;&lt;p data-start=&quot;975&quot; data-end=&quot;1033&quot;&gt;System should &lt;strong data-start=&quot;989&quot; data-end=&quot;1032&quot;&gt;recommend videos based on watch history&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;d4t5pv&quot; data-start=&quot;1035&quot; data-end=&quot;1094&quot;&gt;&#xa;&lt;p data-start=&quot;1038&quot; data-end=&quot;1094&quot;&gt;User should be able to &lt;strong data-start=&quot;1061&quot; data-end=&quot;1093&quot;&gt;search videos using keywords&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1xk5i86&quot; data-start=&quot;1096&quot; data-end=&quot;1164&quot;&gt;&#xa;&lt;p data-start=&quot;1099&quot; data-end=&quot;1164&quot;&gt;System should support &lt;strong data-start=&quot;1121&quot; data-end=&quot;1163&quot;&gt;video history and watch later playlist&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;r453lz&quot; data-start=&quot;1166&quot; data-end=&quot;1242&quot;&gt;&#xa;&lt;p data-start=&quot;1170&quot; data-end=&quot;1242&quot;&gt;Creator should be able to &lt;strong data-start=&quot;1196&quot; data-end=&quot;1241&quot;&gt;view analytics (views, likes, watch time)&lt;/strong&gt;.&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ol&gt;&#xa;&lt;hr data-start=&quot;1244&quot; data-end=&quot;1247&quot;&gt;&#xa;&lt;h1 data-section-id=&quot;181znlz&quot; data-start=&quot;1249&quot; data-end=&quot;1278&quot;&gt;Non-Functional Requirements&lt;/h1&gt;&#xa;&lt;h3 data-section-id=&quot;jx92ls&quot; data-start=&quot;1280&quot; data-end=&quot;1299&quot;&gt;1. Target Scale&lt;/h3&gt;&#xa;&lt;p data-start=&quot;1300&quot; data-end=&quot;1307&quot;&gt;Assume:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;1309&quot; data-end=&quot;1389&quot;&gt;&#xa;&lt;li data-section-id=&quot;s0y3f&quot; data-start=&quot;1309&quot; data-end=&quot;1330&quot;&gt;&#xa;&lt;p data-start=&quot;1311&quot; data-end=&quot;1330&quot;&gt;&lt;strong data-start=&quot;1311&quot; data-end=&quot;1330&quot;&gt;2 Billion users&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1c6f08o&quot; data-start=&quot;1331&quot; data-end=&quot;1353&quot;&gt;&#xa;&lt;p data-start=&quot;1333&quot; data-end=&quot;1353&quot;&gt;&lt;strong data-start=&quot;1333&quot; data-end=&quot;1353&quot;&gt;1 Billion videos&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;2cl0bu&quot; data-start=&quot;1354&quot; data-end=&quot;1389&quot;&gt;&#xa;&lt;p data-start=&quot;1356&quot; data-end=&quot;1389&quot;&gt;&lt;strong data-start=&quot;1356&quot; data-end=&quot;1389&quot;&gt;5 Billion video views per day&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;p data-start=&quot;1391&quot; data-end=&quot;1406&quot;&gt;Storage needed:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;1408&quot; data-end=&quot;1489&quot;&gt;&#xa;&lt;li data-section-id=&quot;1p2vjfi&quot; data-start=&quot;1408&quot; data-end=&quot;1446&quot;&gt;&#xa;&lt;p data-start=&quot;1410&quot; data-end=&quot;1446&quot;&gt;Petabytes of storage for video files&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;92wpwc&quot; data-start=&quot;1447&quot; data-end=&quot;1489&quot;&gt;&#xa;&lt;p data-start=&quot;1449&quot; data-end=&quot;1489&quot;&gt;Metadata stored in distributed databases&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;hr data-start=&quot;1491&quot; data-end=&quot;1494&quot;&gt;&#xa;&lt;h3 data-section-id=&quot;xhb31g&quot; data-start=&quot;1496&quot; data-end=&quot;1514&quot;&gt;2. CAP Theorem&lt;/h3&gt;&#xa;&lt;p data-start=&quot;1516&quot; data-end=&quot;1527&quot;&gt;Prioritize:&lt;/p&gt;&#xa;&lt;p data-start=&quot;1529&quot; data-end=&quot;1561&quot;&gt;&lt;strong data-start=&quot;1529&quot; data-end=&quot;1561&quot;&gt;Availability &amp;gt;&amp;gt;&amp;gt; Consistency&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;p data-start=&quot;1563&quot; data-end=&quot;1585&quot;&gt;(Eventual Consistency)&lt;/p&gt;&#xa;&lt;p data-start=&quot;1587&quot; data-end=&quot;1595&quot;&gt;Example:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;1597&quot; data-end=&quot;1672&quot;&gt;&#xa;&lt;li data-section-id=&quot;1s65y44&quot; data-start=&quot;1597&quot; data-end=&quot;1635&quot;&gt;&#xa;&lt;p data-start=&quot;1599&quot; data-end=&quot;1635&quot;&gt;View count may update slightly later&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1i1d785&quot; data-start=&quot;1636&quot; data-end=&quot;1672&quot;&gt;&#xa;&lt;p data-start=&quot;1638&quot; data-end=&quot;1672&quot;&gt;Likes may take few seconds to sync&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;hr data-start=&quot;1674&quot; data-end=&quot;1677&quot;&gt;&#xa;&lt;h3 data-section-id=&quot;oeen3n&quot; data-start=&quot;1679&quot; data-end=&quot;1693&quot;&gt;3. Latency&lt;/h3&gt;&#xa;&lt;p data-start=&quot;1695&quot; data-end=&quot;1710&quot;&gt;Target latency:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;1712&quot; data-end=&quot;1781&quot;&gt;&#xa;&lt;li data-section-id=&quot;vbh2vh&quot; data-start=&quot;1712&quot; data-end=&quot;1745&quot;&gt;&#xa;&lt;p data-start=&quot;1714&quot; data-end=&quot;1745&quot;&gt;Video load time: &lt;strong data-start=&quot;1731&quot; data-end=&quot;1745&quot;&gt;&amp;lt; 1 second&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1jbs307&quot; data-start=&quot;1746&quot; data-end=&quot;1781&quot;&gt;&#xa;&lt;p data-start=&quot;1748&quot; data-end=&quot;1781&quot;&gt;Streaming latency: &lt;strong data-start=&quot;1767&quot; data-end=&quot;1781&quot;&gt;100-300 ms&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;p data-start=&quot;1783&quot; data-end=&quot;1787&quot;&gt;Use:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;1789&quot; data-end=&quot;1825&quot;&gt;&#xa;&lt;li data-section-id=&quot;1qdxyln&quot; data-start=&quot;1789&quot; data-end=&quot;1825&quot;&gt;&#xa;&lt;p data-start=&quot;1791&quot; data-end=&quot;1825&quot;&gt;&lt;strong data-start=&quot;1791&quot; data-end=&quot;1825&quot;&gt;CDN (Content Delivery Network)&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;hr data-start=&quot;1827&quot; data-end=&quot;1830&quot;&gt;&#xa;&lt;h3 data-section-id=&quot;1d0oorw&quot; data-start=&quot;1832&quot; data-end=&quot;1850&quot;&gt;4. Reliability&lt;/h3&gt;&#xa;&lt;p data-start=&quot;1852&quot; data-end=&quot;1866&quot;&gt;System should:&lt;/p&gt;&#xa;&lt;ul data-start=&quot;1868&quot; data-end=&quot;1947&quot;&gt;&#xa;&lt;li data-section-id=&quot;1rg8m5o&quot; data-start=&quot;1868&quot; data-end=&quot;1895&quot;&gt;&#xa;&lt;p data-start=&quot;1870&quot; data-end=&quot;1895&quot;&gt;Avoid &lt;strong data-start=&quot;1876&quot; data-end=&quot;1895&quot;&gt;video buffering&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1jsgm51&quot; data-start=&quot;1896&quot; data-end=&quot;1919&quot;&gt;&#xa;&lt;p data-start=&quot;1898&quot; data-end=&quot;1919&quot;&gt;Prevent &lt;strong data-start=&quot;1906&quot; data-end=&quot;1919&quot;&gt;data loss&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;46es6j&quot; data-start=&quot;1920&quot; data-end=&quot;1947&quot;&gt;&#xa;&lt;p data-start=&quot;1922&quot; data-end=&quot;1947&quot;&gt;Support &lt;strong data-start=&quot;1930&quot; data-end=&quot;1947&quot;&gt;auto recovery&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ul&gt;&#xa;&lt;hr data-start=&quot;1949&quot; data-end=&quot;1952&quot;&gt;&#xa;&lt;h1 data-section-id=&quot;t0ep34&quot; data-start=&quot;1954&quot; data-end=&quot;1970&quot;&gt;Major Entities&lt;/h1&gt;&#xa;&lt;ol data-start=&quot;1972&quot; data-end=&quot;2102&quot;&gt;&#xa;&lt;li data-section-id=&quot;1lnfwu0&quot; data-start=&quot;1972&quot; data-end=&quot;1984&quot;&gt;&#xa;&lt;p data-start=&quot;1975&quot; data-end=&quot;1984&quot;&gt;&lt;strong data-start=&quot;1975&quot; data-end=&quot;1984&quot;&gt;Users&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;yqhprd&quot; data-start=&quot;1986&quot; data-end=&quot;2001&quot;&gt;&#xa;&lt;p data-start=&quot;1989&quot; data-end=&quot;2001&quot;&gt;&lt;strong data-start=&quot;1989&quot; data-end=&quot;2001&quot;&gt;Channels&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;ya663e&quot; data-start=&quot;2003&quot; data-end=&quot;2016&quot;&gt;&#xa;&lt;p data-start=&quot;2006&quot; data-end=&quot;2016&quot;&gt;&lt;strong data-start=&quot;2006&quot; data-end=&quot;2016&quot;&gt;Videos&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;18bdjhb&quot; data-start=&quot;2018&quot; data-end=&quot;2033&quot;&gt;&#xa;&lt;p data-start=&quot;2021&quot; data-end=&quot;2033&quot;&gt;&lt;strong data-start=&quot;2021&quot; data-end=&quot;2033&quot;&gt;Comments&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;dfibse&quot; data-start=&quot;2035&quot; data-end=&quot;2055&quot;&gt;&#xa;&lt;p data-start=&quot;2038&quot; data-end=&quot;2055&quot;&gt;&lt;strong data-start=&quot;2038&quot; data-end=&quot;2055&quot;&gt;Subscriptions&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;1ax3z9o&quot; data-start=&quot;2057&quot; data-end=&quot;2080&quot;&gt;&#xa;&lt;p data-start=&quot;2060&quot; data-end=&quot;2080&quot;&gt;&lt;strong data-start=&quot;2060&quot; data-end=&quot;2080&quot;&gt;Likes / Dislikes&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;li data-section-id=&quot;jfmtg7&quot; data-start=&quot;2082&quot; data-end=&quot;2102&quot;&gt;&#xa;&lt;p data-start=&quot;2085&quot; data-end=&quot;2102&quot;&gt;&lt;strong data-start=&quot;2085&quot; data-end=&quot;2102&quot;&gt;Watch History&lt;/strong&gt;&lt;/p&gt;&#xa;&lt;/li&gt;&#xa;&lt;/ol&gt;&#xa;&lt;hr data-start=&quot;2104&quot; data-end=&quot;2107&quot;&gt;&#xa;&lt;h1 data-section-id=&quot;1lpxp4e&quot; data-start=&quot;2109&quot; data-end=&quot;2124&quot;&gt;API Endpoints&lt;/h1&gt;&#xa;&lt;h2 data-section-id=&quot;1h0fnzf&quot; data-start=&quot;2126&quot; data-end=&quot;2151&quot;&gt;1. User Authentication&lt;/h2&gt;&#xa;&lt;p data-start=&quot;2153&quot; data-end=&quot;2159&quot;&gt;POST&lt;/p&gt;&#xa;&lt;pre class=&quot;overflow-visible! px-0!&quot; data-start=&quot;2160&quot; data-end=&quot;2183&quot;&gt;&lt;div class=&quot;relative w-full mt-4 mb-1&quot;&gt;&lt;div class=&quot;&quot;&gt;&lt;div class=&quot;relative&quot;&gt;&lt;div class=&quot;h-full min-h-0 min-w-0&quot;&gt;&lt;div class=&quot;h-full min-h-0 min-w-0&quot;&gt;&lt;div class=&quot;border border-token-border-light border-radius-3xl corner-superellipse/1.1 rounded-3xl&quot;&gt;&lt;div class=&quot;h-full w-full border-radius-3xl bg-token-bg-elevated-secondary corner-superellipse/1.1 overflow-clip rounded-3xl lxnfua_clipPathFallback&quot;&gt;&lt;div class=&quot;pointer-events-none absolute end-1.5 top-1 z-2 md:end-2 md:top-1&quot;&gt;&lt;/div&gt;&lt;div class=&quot;pe-11 pt-3&quot;&gt;&lt;div class=&quot;relative z-0 flex max-w-full&quot;&gt;&lt;div id=&quot;code-block-viewer&quot; dir=&quot;ltr&quot; class=&quot;q9tKkq_viewer cm-editor z-10 light:cm-light dark:cm-light 